#!/usr/bin/env sh
# SE Core canonical pre-push.
# 1. Blocks direct pushes to main/master (SE Core PR-flow policy).
#    Override for emergencies: SE_CORE_ALLOW_MAIN_PUSH=1 git push
# 2. Runs typecheck then test scripts if present. Missing scripts skip with log line.

set -e

# --- SE Core PR-flow guard ---
# Git passes refs via stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      if [ "${SE_CORE_ALLOW_MAIN_PUSH:-0}" != "1" ]; then
        echo "[pre-push] Direct push to $remote_ref blocked by SE Core policy." >&2
        echo "[pre-push] Open a branch + PR. Emergency override: SE_CORE_ALLOW_MAIN_PUSH=1 git push" >&2
        exit 1
      fi
      echo "[pre-push] SE_CORE_ALLOW_MAIN_PUSH=1 set; allowing direct push to $remote_ref." >&2
      ;;
  esac
done

command -v node >/dev/null 2>&1 || { echo "[pre-push] node unavailable; skipping"; exit 0; }

if   [ -f pnpm-lock.yaml ];                 then PM=pnpm
elif [ -f bun.lock ] || [ -f bun.lockb ];   then PM=bun
elif [ -f yarn.lock ];                      then PM=yarn
else                                             PM=npm
fi

has_script() {
  node -e "const p=require('./package.json');process.exit((p.scripts||{})['$1']?0:1)" 2>/dev/null
}
run_script() {
  case "$PM" in
    pnpm|bun|yarn) "$PM" run "$1" ;;
    npm)           npm run "$1" ;;
  esac
}

echo "[pre-push] SE Core verification starting..."

if has_script typecheck; then
  run_script typecheck || { echo "[pre-push] typecheck failed"; exit 1; }
else
  echo "[pre-push] no typecheck script - skipping"
fi

if has_script test; then
  run_script test || { echo "[pre-push] tests failed"; exit 1; }
else
  echo "[pre-push] no test script - skipping"
fi

echo "[pre-push] ok"
